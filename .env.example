# =============================================================================
# pingi-ai 환경 변수
# =============================================================================
# 이 파일을 복사하여 .env로 사용한다:
#   cp .env.example .env
# =============================================================================

# --- 서버 설정 ---
# pingi-ai 서버가 실행될 포트 (pingi-backend는 8000, pingi-ai는 8001)
PORT=8001

# --- 임시 파일 경로 ---
# 업로드된 오디오 파일을 변환할 때 사용하는 임시 디렉토리
TEMP_DIR=./tmp
